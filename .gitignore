```gitignore
# Compiled Python files
__pycache__/
*.pyc
*.pyo
*.pyd

# Dependencies
venv/
.venv/
.env
.env.local
.env.*

# Logs and temporary files
*.log
*.tmp

# Editors
.vscode/
.idea/

# Build artifacts
dist/
build/
target/

# Coverage reports
.coverage
coverage/
htmlcov/

# Migration backups
migrations/*.sql.bak
migrations/*.backup
```