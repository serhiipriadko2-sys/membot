{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Entry Context Row",
  "type": "object",
  "required": [
    "entry_signature",
    "token_mint",
    "entry_time",
    "entry_slot",
    "label_win",
    "label_pnl_sol",
    "context_status",
    "feature_coverage_pct",
    "leakage_guard_ok"
  ],
  "properties": {
    "entry_signature": {"type": "string"},
    "token_mint": {"type": "string"},
    "entry_time": {"type": ["integer", "string"]},
    "entry_time_utc": {"type": "string"},
    "entry_slot": {"type": ["integer", "string"]},
    "entry_sol": {"type": ["number", "string"]},
    "label_win": {"type": ["boolean", "string"]},
    "label_pnl_sol": {"type": ["number", "string"]},
    "label_hold_seconds": {"type": ["integer", "string"]},
    "price_return_30s": {"type": ["number", "string"]},
    "wallet_buy_count_30s": {"type": ["number", "string"]},
    "wallet_sell_count_30s": {"type": ["number", "string"]},
    "wallet_net_buy_sol_30s": {"type": ["number", "string"]},
    "same_wallet_prior_entries_count": {"type": ["number", "string"]},
    "same_wallet_prior_pnl_sol": {"type": ["number", "string"]},
    "feature_family": {"type": "string"},
    "feature_source": {"type": "string"},
    "feature_coverage_pct": {"type": ["number", "string"], "minimum": 0, "maximum": 100},
    "confidence": {"type": "string"},
    "market_coverage": {"type": "string"},
    "context_status": {"enum": ["PASS", "PARTIAL", "UNKNOWN", "FAIL", "NO_SIGNAL"]},
    "context_coverage": {"type": "string"},
    "leakage_guard_ok": {"type": ["boolean", "string"]},
    "unknown_fields_count": {"type": ["integer", "string"]},
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
