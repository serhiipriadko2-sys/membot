# -- Target ---------------------------------------------------------
TARGET_WALLET=7BNaxx6KdUYrjACNQZ9He26NBFoFxujQMAfNLnArLGH5

# -- RPC Providers -------------------------------------------------
# Set at least SOLANA_RPC_URL. The JSON-RPC pipeline reads this one.
# The other RPC URLs may be probed by a health gate as fallback candidates.
# Do not commit real API keys. Copy this file to .env locally.
# Helius JSON-RPC example:
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
SOLANA_RPC_URL=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
QUICKNODE_RPC_URL=
TRITON_RPC_URL=
CUSTOM_RPC_URL=

# -- Helius Enhanced Transactions API ------------------------------
# These are REST endpoints, not JSON-RPC endpoints. Do not put them in SOLANA_RPC_URL.
HELIUS_API_KEY=YOUR_HELIUS_API_KEY
HELIUS_ENHANCED_TX_URL=https://api-mainnet.helius-rpc.com/v0/transactions/?api-key=YOUR_HELIUS_API_KEY
HELIUS_ADDRESS_TX_URL_TEMPLATE=https://api-mainnet.helius-rpc.com/v0/addresses/{address}/transactions/?api-key=YOUR_HELIUS_API_KEY

# -- Helius WebSocket ----------------------------------------------
HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# -- RPC Tuning ----------------------------------------------------
SOLANA_COMMITMENT=finalized
REQUEST_SLEEP_SECONDS=0.15
RPC_MAX_RETRIES=5
